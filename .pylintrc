[MAIN]
# Specify a score threshold to exit with error status if less
fail-under=7.0

# Files or directories to be excluded from analysis
ignore=venv,__pycache__,.git,build,dist

# Python interpreter version
py-version=3.8

# Allow pylint to load C extension modules (needed for PyQt6)
extension-pkg-allow-list=PyQt6

[MESSAGES CONTROL]
# Disable specific messages
disable=
    C0114,  # missing-module-docstring (some files are simple)
    C0116,  # missing-function-docstring (some obvious functions)
    R0902,  # too-many-instance-attributes (UI classes need many)
    R0903,  # too-few-public-methods (mixins, data classes)
    R0913,  # too-many-arguments (some complex functions need them)
    R0915,  # too-many-statements (complex UI setup methods)
    W0201,  # attribute-defined-outside-init (UI pattern)
    W0511,  # fixme (allow TODO comments)
    W0718,  # broad-exception-caught (intentional catch-all in some places)
    E1101,  # no-member (false positives with PyQt6)
    R0801,  # duplicate-code (themes share structure intentionally)

[FORMAT]
# Maximum line length
max-line-length=120

# Indent string
indent-string='    '

[DESIGN]
# Maximum number of arguments for a function
max-args=8

# Maximum number of local variables
max-locals=20

# Maximum number of public methods per class
max-public-methods=30

# Maximum number of return statements per function
max-returns=8

# Maximum nesting depth
max-nested-blocks=5

[SIMILARITIES]
# Minimum lines for code duplication check
min-similarity-lines=10

[BASIC]
# Good variable names
good-names=i,j,k,ex,_,id,db,gh,ui

# Regular expression for valid module names
module-rgx=[a-z_][a-z0-9_]*$

# Regular expression for valid class names  
class-rgx=[A-Z_][a-zA-Z0-9]+$

# Regular expression for valid function names
function-rgx=[a-z_][a-z0-9_]*$

# Regular expression for valid method names (allow Qt camelCase overrides)
method-rgx=([a-z_][a-z0-9_]*|show[A-Z][a-zA-Z]*|highlight[A-Z][a-zA-Z]*)$

[IMPORTS]
# List of modules that can be imported at any level
allow-any-import-level=

# Allow wildcard imports from modules
allow-wildcard-with-all=no

[TYPECHECK]
# List of classes names for which member attributes should not be checked
ignored-classes=
    SQLAlchemy,
    scoped_session,
    PyQt6,
    QWidget,
    QMainWindow,
    QDialog
